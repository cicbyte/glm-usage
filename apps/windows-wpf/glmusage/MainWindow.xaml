<Window x:Class="glmusage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:glmusage"
        xmlns:cvt="clr-namespace:glmusage.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GLM Usage"
        Width="90" Height="90"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">

    <Window.Resources>
        <cvt:PercentageToColorConverter x:Key="PercColorConv" WarningThreshold="70" DangerThreshold="80"/>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="#000000"/>

        <!-- Tooltip 样式 -->
        <Style x:Key="BallToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#1C2333"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- 悬浮球 -->
        <Border x:Name="BallBorder"
                Width="90" Height="90"
                CornerRadius="45"
                Cursor="Hand"
                MouseEnter="Ball_MouseEnter"
                MouseLeave="Ball_MouseLeave">
            <Border.ToolTip>
                <ToolTip x:Name="BallToolTip" Style="{StaticResource BallToolTipStyle}"
                         Placement="Right" HorizontalOffset="10" VerticalOffset="-20">
                    <StackPanel x:Name="ToolTipContent">
                        <TextBlock x:Name="TipTitle" Text="GLM Coding" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#E6EDF3" Margin="0,0,0,6"/>
                        <StackPanel x:Name="TipLimits"/>
                        <TextBlock x:Name="TipUpdated" Text="加载中..."
                                   FontSize="10" Foreground="#484F58" Margin="0,6,0,0"/>
                    </StackPanel>
                </ToolTip>
            </Border.ToolTip>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A2332" Offset="0"/>
                    <GradientStop Color="#0D1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush x:Name="BallBorderBrush" Color="#30363D"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1.5</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect x:Name="BallGlow" BlurRadius="16" ShadowDepth="0" Opacity="0.3" Color="#2ECC71"/>
            </Border.Effect>
            <Grid>
                <!-- 水位填充 -->
                <Path x:Name="WaterFill" Width="86" Height="86"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Stretch="None">
                    <Path.Clip>
                        <EllipseGeometry Center="43,43" RadiusX="43" RadiusY="43"/>
                    </Path.Clip>
                </Path>
                <!-- 悬浮旋转光弧：紫 -->
                <Ellipse x:Name="HoverArc1" Width="86" Height="86"
                         Stroke="#BF5AF2" StrokeThickness="3"
                         StrokeDashArray="35 235"
                         StrokeDashCap="Round"
                         Opacity="0"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         RenderTransformOrigin="0.5 0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="HoverArc1Rotation" Angle="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- 悬浮旋转光弧：青 -->
                <Ellipse x:Name="HoverArc2" Width="86" Height="86"
                         Stroke="#64D2FF" StrokeThickness="2.5"
                         StrokeDashArray="28 242"
                         StrokeDashCap="Round"
                         Opacity="0"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         RenderTransformOrigin="0.5 0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="HoverArc2Rotation" Angle="120"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- 悬浮旋转光弧：粉 -->
                <Ellipse x:Name="HoverArc3" Width="86" Height="86"
                         Stroke="#FF6482" StrokeThickness="2"
                         StrokeDashArray="22 248"
                         StrokeDashCap="Round"
                         Opacity="0"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         RenderTransformOrigin="0.5 0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="HoverArc3Rotation" Angle="240"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- 内容文字 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="PercentText"
                               Text="--%"
                               FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,0,0,0"/>
                    <TextBlock x:Name="SubText"
                               Text="GLM"
                               FontFamily="Segoe UI" FontSize="8"
                               Foreground="#8B949E" HorizontalAlignment="Center"
                               Margin="0,0,0,0"/>
                </StackPanel>
                <!-- 错误标识 -->
                <Border x:Name="ErrorBadge"
                        Width="16" Height="16" CornerRadius="8" Background="#E74C3C"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="!" FontSize="10" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- 详情面板 -->
        <Border x:Name="DetailPanel"
                Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,90,0,-260"
                CornerRadius="12"
                Visibility="Collapsed"
                d:Visibility="Visible">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1C2333" Offset="0"/>
                    <GradientStop Color="#161B22" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#30363D"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Border.Effect>
                <StaticResource ResourceKey="PanelShadow"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelTransform" Y="20"/>
            </Border.RenderTransform>

            <StackPanel>
                <!-- 面板头部 -->
                <Border Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#21262D">
                    <DockPanel>
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="#2ECC71" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="DetailTitle"
                                   Text="GLM Coding"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailUpdated"
                                   FontSize="9" Foreground="#484F58"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- 内容区 -->
                <StackPanel x:Name="DetailContent" Margin="14,10">
                    <!-- 由 code-behind 动态填充 -->
                </StackPanel>

                <!-- 分隔线 -->
                <Separator Margin="12,0"/>

                <!-- 操作按钮 -->
                <DockPanel Margin="12,10">
                    <Button Click="Refresh_Click" Style="{StaticResource DetailButtonStyle}"
                            DockPanel.Dock="Left" Width="70">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="刷新" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Settings_Click" Style="{StaticResource DetailButtonStyle}"
                            DockPanel.Dock="Left" Width="70">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="设置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Exit_Click" Style="{StaticResource DetailButtonStyle}"
                            HorizontalAlignment="Right" Width="70">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="退出" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- 右键菜单 -->
    <Window.ContextMenu>
        <ContextMenu x:Name="CtxMenu">
            <MenuItem Click="Refresh_Click">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="#8B949E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
            <MenuItem Click="Settings_Click">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="#8B949E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="设置" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
            <Separator Style="{StaticResource CtxSeparator}"/>
            <MenuItem Click="Exit_Click">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="#E74C3C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="退出" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>
</Window>
