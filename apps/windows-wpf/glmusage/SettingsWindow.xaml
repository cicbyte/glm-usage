<Window x:Class="glmusage.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="380" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="12" Background="#0D1117"
            BorderBrush="#21262D" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Padding="20,14" BorderThickness="0,0,0,1" BorderBrush="#21262D"
                    Background="Transparent"
                    PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="#2ECC71" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="设置" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E6EDF3" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 设置项（无滚动条） -->
            <StackPanel Grid.Row="1" Margin="20,12,20,8">
                <!-- API 设置 -->
                <TextBlock Text="API 配置" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,4,0,10"/>

                <TextBlock Text="API Key" FontSize="12" Foreground="#8B949E" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ApiKeyBox"/>
                    <Button x:Name="ToggleKeyVisBtn" Grid.Column="1" Width="34" Margin="2,0,0,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="ToggleKeyVis_Click" VerticalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="0,6,6,0">
                                    <TextBlock x:Name="EyeIcon" Text="显示" FontSize="11"
                                               Foreground="#8B949E" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" TargetName="Bd" Value="#21262D"/>
                                        <Setter Property="Foreground" TargetName="EyeIcon" Value="#E6EDF3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <TextBlock Text="Base URL" FontSize="12" Foreground="#8B949E" Margin="0,0,0,5"/>
                <TextBox x:Name="BaseUrlBox" Margin="0,0,0,14"/>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="刷新间隔" FontSize="12" Foreground="#8B949E"
                               VerticalAlignment="Center"/>
                    <Grid HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Width="120">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RefreshBox" TextAlignment="Center"
                                     VerticalContentAlignment="Center" Padding="4,6"
                                     InputScope="Number"/>
                            <StackPanel Grid.Column="1" Margin="1,0,0,0" VerticalAlignment="Stretch">
                            <RepeatButton Height="14" BorderThickness="0"
                                          Background="#21262D" Foreground="#8B949E"
                                          FontSize="8" Content="▲" Cursor="Hand"
                                          Click="SpinUp_Click">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="0,6,0,0" Padding="0,2,4,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="Bd" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                            <RepeatButton Height="14" BorderThickness="0"
                                          Background="#21262D" Foreground="#8B949E"
                                          FontSize="8" Content="▼" Cursor="Hand"
                                          Click="SpinDown_Click">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="0,0,6,0" Padding="0,0,4,2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="Bd" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="秒" FontSize="11" Foreground="#484F58"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>
            </DockPanel>

                <!-- 其他 -->
                <TextBlock Text="其他" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,2,0,10"/>

                <CheckBox x:Name="AutoStartBox" Content="开机自启" Margin="0,0,0,8"/>
                <CheckBox x:Name="NotifBox" Content="显示系统通知"/>
            </StackPanel>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="#21262D">
                <Grid>
                    <Button Content="取消" Click="Cancel_Click"
                            Style="{StaticResource SecondaryButton}" Width="90" Height="32"
                            HorizontalAlignment="Left"/>
                    <Button Content="保存" Click="Save_Click"
                            Style="{StaticResource PrimaryButton}" Width="90" Height="32"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
