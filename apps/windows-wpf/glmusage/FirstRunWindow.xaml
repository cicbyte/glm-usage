<Window x:Class="glmusage.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GLM Usage"
        Width="440" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowActivated="True"
        Loaded="Window_Loaded"
        FocusManager.FocusedElement="{Binding ElementName=ApiKeyBox}">

    <Border CornerRadius="16" Background="#0D1117"
            BorderBrush="#21262D" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="32" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0" Width="48" Height="48" CornerRadius="14"
                    Background="#161B22" HorizontalAlignment="Left"
                    BorderBrush="#21262D" BorderThickness="1"
                    Margin="0,0,0,20">
                <TextBlock Text="G" FontSize="22" FontWeight="Bold"
                           Foreground="#2ECC71" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
            </Border>

            <!-- 标题 -->
            <TextBlock Grid.Row="1"
                       Text="欢迎使用 GLM Usage"
                       FontSize="20" FontWeight="Bold" Foreground="#E6EDF3"
                       Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2"
                       Text="请输入您的 GLM API Key 以开始监控用量。"
                       FontSize="13" Foreground="#8B949E"
                       TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20"/>

            <TextBlock Grid.Row="3"
                       Text="API Key"
                       FontSize="12" Foreground="#484F58"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <TextBox Grid.Row="4"
                     x:Name="ApiKeyBox"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     TextWrapping="Wrap" AcceptsReturn="False"
                     SpellCheck.IsEnabled="False"/>

            <Button Grid.Row="5"
                    Content="开始使用"
                    Click="Start_Click"
                    Style="{StaticResource PrimaryButton}"
                    Width="120" Height="38" FontSize="14"
                    HorizontalAlignment="Right" Margin="0,16,0,0"
                    IsDefault="True"/>
        </Grid>
    </Border>
</Window>
